"name": "LoginAPITest.java",
"content": "package tests.api;\n\nimport com.framework.data.UserCredentials;\nimport com.framework.data.UserDataFactory;\nimport com.framework.services.AuthService;\nimport com.framework.utils.JsonSchemaValidatorUtil;\nimport com.framework.utils.annotations.Feature;\nimport com.framework.utils.annotations.Priority;\nimport com.framework.utils.annotations.Scenario;\nimport com.framework.utils.annotations.Tags;\nimport io.restassured.response.Response;\nimport org.testng.Assert;\nimport org.testng.annotations.Test;\n\npublic class LoginAPITest {\n\n    private final AuthService authService = new AuthService();\n\n    @Test\n    @Feature(\"Login API\")\n    @Scenario(\"Valid user receives token and matches schema\")\n    @Priority(\"P1\")\n    @Tags({\"api\", \"smoke\", \"login\"})\n    public void validUserLoginReturnsToken() {\n        UserCredentials user = UserDataFactory.validUser();\n\n        Response response = authService.login(user.getUsername(), user.getPassword());\n        Assert.assertEquals(response.getStatusCode(), 200, \"Status code should be 200\");\n        Assert.assertNotNull(response.jsonPath().get(\"token\"), \"Token should be present in response\");\n\n        JsonSchemaValidatorUtil.validateSchema(response, \"schemas/login-response-schema.json\");\n    }\n\n    @Test\n    @Feature(\"Login API\")\n    @Scenario(\"Invalid user receives 401\")\n    @Priority(\"P2\")\n    @Tags({\"api\", \"regression\", \"login\"})\n    public void invalidUserLoginReturnsUnauthorized() {\n        UserCredentials user = UserDataFactory.randomUser();\n\n        Response response = authService.login(user.getUsername(), user.getPassword());\n        Assert.assertEquals(response.getStatusCode(), 401, \"Status code should be 401 for invalid user\");\n    }\n}\n"
}
]
