package com.framework.selfhealing;

import com.microsoft.playwright.Locator;
import com.microsoft.playwright.Page;
import io.restassured.response.Response;

import java.util.Optional;

public class SelfHealingOrchestrator {

    private final TimingHealingModule timingModule;
    private final StateHealingModule stateModule;
    private final NavigationHealingModule navigationModule;
    private final ApiSchemaHealingModule apiSchemaModule;
    private final HealingStore healingStore;

    public SelfHealingOrchestrator(HealingStore healingStore) {
        this.healingStore = healingStore;
        this.timingModule = new TimingHealingModule();
        this.stateModule = new StateHealingModule();
        this.navigationModule = new NavigationHealingModule();
        this.apiSchemaModule = new ApiSchemaHealingModule(healingStore);
    }

    // UI: resolve locator with healing
    public Locator resolveLocator(Page page, SmartLocator smartLocator) {
        // 1. Try primary
        Locator locator = page.locator(smartLocator.getPrimary());
        if (locator.count() > 0) {
            return locator;
        }

        // 2. Try stored healed locator
        Optional<String> healed = healingStore.getHealedLocator(smartLocator.getKey());
        if (healed.isPresent()) {
            Locator healedLocator = page.locator(healed.get());
            if (healedLocator.count() > 0) {
                return healedLocator;
            }
        }

        // 3. Try fallbacks
        for (String fb : smartLocator.getFallbacks()) {
            Locator fbLocator = page.locator(fb);
            if (fbLocator.count() > 0) {
                healingStore.saveHealedLocator(smartLocator.getKey(), fb);
                return fbLocator;
            }
        }

        // 4. Try heuristic (e.g., text-based)
        if (smartLocator.getHeuristicSelector() != null) {
            Locator heuristic = page.locator(smartLocator.getHeuristicSelector());
            if (heuristic.count() > 0) {
                healingStore.saveHealedLocator(smartLocator.getKey(), smartLocator.getHeuristicSelector());
                return heuristic;
            }
        }

        // 5. Last resort: return primary (will fail, but logged)
        return locator;
    }

    // UI: heal click failures (timing + state)
    public boolean healClickFailure(Page page, SmartLocator smartLocator) {
        Locator locator = resolveLocator(page, smartLocator);
        if (timingModule.waitForVisible(locator)) {
            if (stateModule.ensureClickable(page, locator)) {
                locator.click();
                return true;
            }
        }
        return false;
    }

    // API: heal schema drift
    public Response healApiSchema(Response response, String schemaKey) {
        return apiSchemaModule.handleSchemaDrift(response, schemaKey);
    }
}
