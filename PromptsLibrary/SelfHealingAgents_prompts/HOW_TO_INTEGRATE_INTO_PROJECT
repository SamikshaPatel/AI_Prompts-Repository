"name": "LoginUITest.java",
"content": "package tests.ui;\n\nimport com.framework.core.BaseTest;\nimport com.framework.data.UserCredentials;\nimport com.framework.data.UserDataFactory;\nimport com.framework.pages.HomePage;\nimport com.framework.pages.LoginPage;\nimport com.framework.utils.annotations.Feature;\nimport com.framework.utils.annotations.Priority;\nimport com.framework.utils.annotations.Scenario;\nimport com.framework.utils.annotations.Tags;\nimport org.testng.Assert;\nimport org.testng.annotations.Test;\n\npublic class LoginUITest extends BaseTest {\n\n    @Test(retryAnalyzer = com.framework.listeners.RetryAnalyzer.class)\n    @Feature(\"Login\")\n    @Scenario(\"Valid user can log in and see welcome message\")\n    @Priority(\"P1\")\n    @Tags({\"ui\", \"smoke\", \"login\"})\n    public void validUserCanLogin() {\n        UserCredentials user = UserDataFactory.validUser();\n\n        LoginPage loginPage = new LoginPage().navigateTo();\n        loginPage.enterUsername(user.getUsername())\n                 .enterPassword(user.getPassword())\n                 .submit();\n\n        HomePage homePage = new HomePage();\n        String welcomeText = homePage.getWelcomeText();\n        Assert.assertTrue(welcomeText != null && welcomeText.contains(user.getUsername()),\n                \"Welcome text should contain username\");\n    }\n\n    @Test(retryAnalyzer = com.framework.listeners.RetryAnalyzer.class)\n    @Feature(\"Login\")\n    @Scenario(\"Invalid user sees error message\")\n    @Priority(\"P2\")\n    @Tags({\"ui\", \"regression\", \"login\"})\n    public void invalidUserSeesError() {\n        UserCredentials user = UserDataFactory.randomUser();\n\n        LoginPage loginPage = new LoginPage().navigateTo();\n        loginPage.enterUsername(user.getUsername())\n                 .enterPassword(user.getPassword())\n                 .submit();\n\n        String error = loginPage.getErrorMessage();\n        Assert.assertTrue(error != null && !error.isEmpty(), \"Error message should be displayed\");\n    }\n}\n"
}
