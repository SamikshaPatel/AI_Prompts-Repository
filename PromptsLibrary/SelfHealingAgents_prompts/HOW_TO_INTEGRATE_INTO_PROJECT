package com.framework.selfhealing;

import java.util.ArrayList;
import java.util.Collections;
import java.util.List;
import java.util.Objects;

public class SmartLocator {

    private final String key;              // unique logical key, e.g. "login.username"
    private final String primary;
    private final List<String> fallbacks;
    private final String heuristicSelector;

    private SmartLocator(Builder builder) {
        this.key = Objects.requireNonNull(builder.key, "key must not be null");
        this.primary = Objects.requireNonNull(builder.primary, "primary locator must not be null");
        this.fallbacks = Collections.unmodifiableList(new ArrayList<>(builder.fallbacks));
        this.heuristicSelector = builder.heuristicSelector;
    }

    public String getKey() {
        return key;
    }

    public String getPrimary() {
        return primary;
    }

    public List<String> getFallbacks() {
        return fallbacks;
    }

    public String getHeuristicSelector() {
        return heuristicSelector;
    }

    public static Builder builder(String key, String primary) {
        return new Builder(key, primary);
    }

    public static class Builder {
        private final String key;
        private final String primary;
        private final List<String> fallbacks = new ArrayList<>();
        private String heuristicSelector;

        public Builder(String key, String primary) {
            this.key = key;
            this.primary = primary;
        }

        public Builder addFallback(String locator) {
            this.fallbacks.add(locator);
            return this;
        }

        public Builder heuristic(String locator) {
            this.heuristicSelector = locator;
            return this;
        }

        public SmartLocator build() {
            return new SmartLocator(this);
        }
    }
}
