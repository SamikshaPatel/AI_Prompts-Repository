package com.framework.selfhealing;

import com.fasterxml.jackson.core.type.TypeReference;
import com.fasterxml.jackson.databind.ObjectMapper;

import java.io.File;
import java.io.IOException;
import java.util.Collections;
import java.util.HashMap;
import java.util.Map;
import java.util.Optional;

public class HealingStore {

    private static final String DEFAULT_PATH = "artifacts/healing/locators.json";

    private final File storeFile;
    private final ObjectMapper mapper;
    private Map<String, String> healedLocators;

    public HealingStore() {
        this(DEFAULT_PATH);
    }

    public HealingStore(String path) {
        this.storeFile = new File(path);
        this.mapper = new ObjectMapper();
        this.healedLocators = load();
    }

    private Map<String, String> load() {
        if (!storeFile.exists()) {
            return new HashMap<>();
        }
        try {
            return mapper.readValue(storeFile, new TypeReference<Map<String, String>>() {});
        } catch (IOException e) {
            return new HashMap<>();
        }
    }

    private void persist() {
        storeFile.getParentFile().mkdirs();
        try {
            mapper.writerWithDefaultPrettyPrinter().writeValue(storeFile, healedLocators);
        } catch (IOException e) {
            // best-effort; do not break tests
        }
    }

    public Optional<String> getHealedLocator(String key) {
        return Optional.ofNullable(healedLocators.get(key));
    }

    public void saveHealedLocator(String key, String locator) {
        healedLocators.put(key, locator);
        persist();
    }

    public Map<String, String> snapshot() {
        return Collections.unmodifiableMap(healedLocators);
    }
}
